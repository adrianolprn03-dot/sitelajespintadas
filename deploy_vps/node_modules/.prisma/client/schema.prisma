generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  senha        String
  perfil       String   @default("editor")
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Secretaria {
  id                   String    @id @default(cuid())
  nome                 String
  slug                 String    @unique
  descricao            String
  servicos             String    @default("[]")
  contato              String?
  telefone             String?
  email                String?
  endereco             String?
  secretario           String?
  imagem               String?
  horarioFuncionamento String?
  ativa                Boolean   @default(true)
  ordem                Int       @default(0)
  criadoEm             DateTime  @default(now())
  noticias             Noticia[]
}

model Noticia {
  id           String      @id @default(cuid())
  titulo       String
  slug         String      @unique
  resumo       String
  conteudo     String
  imagem       String?
  publicada    Boolean     @default(false)
  destaque     Boolean     @default(false)
  publicadoEm  DateTime?
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt
  secretariaId String?
  tags         String      @default("[]")
  secretaria   Secretaria? @relation(fields: [secretariaId], references: [id])
}

model Licitacao {
  id               String     @id @default(cuid())
  numero           String
  ano              Int
  modalidade       String
  objeto           String
  valor            Float?
  status           String     @default("aberta")
  dataAbertura     DateTime?
  dataEncerramento DateTime?
  secretaria       String
  documentos       String     @default("[]")
  resultado        String?
  criadoEm         DateTime   @default(now())
  contratos        Contrato[]
}

model Contrato {
  id             String     @id @default(cuid())
  numero         String
  objeto         String
  fornecedor     String
  cnpjFornecedor String?
  valor          Float
  dataInicio     DateTime
  dataFim        DateTime
  secretaria     String
  status         String     @default("vigente")
  documentos     String     @default("[]")
  licitacaoId    String?
  criadoEm       DateTime   @default(now())
  licitacao      Licitacao? @relation(fields: [licitacaoId], references: [id])
}

model Convenio {
  id            String   @id @default(cuid())
  numero        String
  objeto        String
  concedente    String
  valor         Float
  contrapartida Float    @default(0)
  dataInicio    DateTime
  dataFim       DateTime
  secretaria    String
  status        String   @default("vigente")
  documentos    String   @default("[]")
  criadoEm      DateTime @default(now())
}

model Diaria {
  id             String   @id @default(cuid())
  servidor       String
  cargo          String
  destino        String
  motivo         String
  dataInicio     DateTime
  dataFim        DateTime
  valor          Float
  valorUnitario  Float    @default(0)
  quantidadeDias Float    @default(1)
  secretaria     String
  mes            Int
  ano            Int
  portariaUrl    String?
  criadoEm       DateTime @default(now())
}

model Servidor {
  id           String   @id @default(cuid())
  nome         String
  matricula    String?  @unique
  cargo        String
  vinculo      String   @default("efetivo")
  secretaria   String
  salarioBase  Float
  totalBruto   Float
  totalLiquido Float
  ativo        Boolean  @default(true)
  mes          Int
  ano          Int
  criadoEm     DateTime @default(now())
}

model Receita {
  id        String   @id @default(cuid())
  descricao String
  categoria String
  fonte     String?
  valor     Float
  mes       Int
  ano       Int
  criadoEm  DateTime @default(now())
}

model Despesa {
  id         String   @id @default(cuid())
  descricao  String
  categoria  String
  secretaria String
  fornecedor String?
  valor      Float
  mes        Int
  ano        Int
  criadoEm   DateTime @default(now())
}

model Documento {
  id           String   @id @default(cuid())
  titulo       String
  tipo         String
  arquivo      String?
  documentUrl  String?
  tamanho      Int?
  ano          Int?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt
}

model Evento {
  id         String    @id @default(cuid())
  titulo     String
  descricao  String?
  local      String?
  dataInicio DateTime
  dataFim    DateTime?
  publico    Boolean   @default(true)
  criadoEm   DateTime  @default(now())
}

model Contato {
  id         String   @id @default(cuid())
  nome       String
  email      String
  telefone   String?
  assunto    String
  mensagem   String
  respondido Boolean  @default(false)
  criadoEm   DateTime @default(now())
}

model Ouvidoria {
  id                  String    @id @default(cuid())
  protocolo           String    @unique @default(cuid())
  tipo                String
  assunto             String
  descricao           String
  nome                String?
  email               String?
  anonimo             Boolean   @default(false)
  status              String    @default("aberto")
  resposta            String?
  respondidoEm        DateTime?
  prazo               DateTime?
  prorrogado          Boolean   @default(false)
  anexoResposta       String?
  recurso             String?
  dataRecurso         DateTime?
  respostaRecurso     String?
  dataRespostaRecurso DateTime?
  criadoEm            DateTime  @default(now())
}

model Esic {
  id                  String       @id @default(cuid())
  protocolo           String       @unique @default(cuid())
  orgao               String
  pedido              String
  nome                String?
  email               String?
  formaRetorno        String       @default("sistema")
  status              String       @default("aberto")
  grauSigilo          String       @default("Sem Sigilo")
  resposta            String?
  respondidoEm        DateTime?
  prazo               DateTime?
  prorrogado          Boolean      @default(false)
  anexoResposta       String?
  recurso             String?
  dataRecurso         DateTime?
  respostaRecurso     String?
  dataRespostaRecurso DateTime?
  criadoEm            DateTime     @default(now())
  cidadaoId           String?
  cidadao             CidadaoEsic? @relation(fields: [cidadaoId], references: [id])
}

model CidadaoEsic {
  id             String    @id @default(cuid())
  nome           String
  tipoPessoa     String    @default("Física")
  cpf            String?   @unique
  cnpj           String?   @unique
  razaoSocial    String?
  email          String    @unique
  senha          String
  telefone       String?
  dataNascimento DateTime?
  sexo           String?
  escolaridade   String?
  cep            String?
  endereco       String?
  numero         String?
  bairro         String?
  cidade         String?
  uf             String?
  dataAbertura   DateTime?
  rg             String?
  orgaoEmissor   String?
  ufEmissor      String?
  profissao      String?
  nomeFantasia   String?
  criadoEm       DateTime  @default(now())
  pedidos        Esic[]
}

model GaleriaFoto {
  id        String   @id @default(cuid())
  titulo    String
  descricao String?
  arquivo   String
  album     String?
  publicada Boolean  @default(true)
  criadoEm  DateTime @default(now())
}

model Obra {
  id              String    @id @default(cuid())
  titulo          String
  descricao       String
  local           String
  valor           Float
  status          String    @default("em-andamento")
  dataInicio      DateTime?
  previsaoTermino DateTime?
  empresa         String?
  percentual      Int       @default(0)
  imagem          String?
  documentos      String    @default("[]")
  criadoEm        DateTime  @default(now())
}

model FAQ {
  id        String   @id @default(cuid())
  pergunta  String
  resposta  String
  categoria String?
  ordem     Int      @default(0)
  criadoEm  DateTime @default(now())
}

model Glossario {
  id        String   @id @default(cuid())
  termo     String
  definicao String
  criadoEm  DateTime @default(now())
}

model Legislacao {
  id           String   @id @default(cuid())
  tipo         String
  categoria    String?
  numero       String
  ano          Int
  ementa       String
  arquivo      String?
  documentUrl  String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt
}

model UnidadeAtendimento {
  id           String   @id @default(cuid())
  nome         String
  tipo         String
  descricao    String
  endereco     String
  telefone     String?
  horario      String
  mapa         String?
  ativa        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Conselho {
  id         String        @id @default(cuid())
  nome       String
  sigla      String?
  tipo       String
  descricao  String
  composicao String
  presidente String?
  email      String?
  ativo      Boolean       @default(true)
  criadoEm   DateTime      @default(now())
  atas       ConselhoAta[]
}

model ConselhoAta {
  id          String   @id @default(cuid())
  conselhoId  String
  titulo      String
  dataReuniao DateTime
  arquivo     String?
  criadoEm    DateTime @default(now())
  conselho    Conselho @relation(fields: [conselhoId], references: [id], onDelete: Cascade)
}

model ImportacaoCSV {
  id       String   @id @default(cuid())
  modulo   String
  arquivo  String
  total    Int      @default(0)
  sucesso  Int      @default(0)
  erros    Int      @default(0)
  status   String   @default("pendente")
  criadoEm DateTime @default(now())
}

model LinkExterno {
  id           String   @id @default(cuid())
  titulo       String
  url          String
  descricao    String?
  categoria    String
  icone        String   @default("FaLink")
  ativo        Boolean  @default(true)
  ordem        Int      @default(0)
  moduloAlvo   String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt
}

model Configuracao {
  id           String   @id @default(cuid())
  chave        String   @unique
  valor        String
  descricao    String?
  grupo        String   @default("geral")
  atualizadoEm DateTime @default(now()) @updatedAt
}

model Medicamento {
  id           String   @id @default(cuid())
  nome         String
  categoria    String
  status       String   @default("disponivel")
  observacao   String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt
}

model Veiculo {
  id           String   @id @default(cuid())
  modelo       String
  placa        String   @unique
  ano          String?
  secretaria   String
  tipo         String
  status       String   @default("em-uso")
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt
}

model EmendaParlamentar {
  id                String   @id @default(cuid())
  objeto            String?
  criadoEm          DateTime @default(now())
  anoEmenda         Int
  atualizadoEm      DateTime @updatedAt
  autorNome         String
  codigoEmenda      String   @unique
  convenioNumero    String?
  dataImportacao    DateTime @default(now())
  favorecidoCnpjCpf String?
  favorecidoNome    String?
  fonteDado         String?
  funcaoGoverno     String?
  instrumentoNumero String?
  localidade        String?
  numeroEmenda      String?
  orgaoConcedente   String?
  planoAcaoNumero   String?
  situacaoExecucao  String?
  subfuncaoGoverno  String?
  tipoEmenda        String?
  uf                String?
  urlFonteOficial   String?
  valorEmpenhado    Float?   @default(0)
  valorLiquidado    Float?   @default(0)
  valorPago         Float?   @default(0)
  valorPrevisto     Float?   @default(0)
}

model Concurso {
  id             String   @id @default(cuid())
  titulo         String
  slug           String   @unique
  tipo           String
  status         String   @default("aberto")
  vagas          String?
  dataPublicacao DateTime @default(now())
  linkEdital     String?
  ativo          Boolean  @default(true)
  criadoEm       DateTime @default(now())
  descricao      String?
}

model ServicoCarta {
  id             String             @id @default(cuid())
  nome           String
  categoria      String
  descricao      String
  local          String
  prazo          String
  documentos     String?
  ativo          Boolean            @default(true)
  ordem          Int                @default(0)
  criadoEm       DateTime           @default(now())
  etapas         String?
  formasAcesso   String?
  linkAvaliacao  String?            @default("/transparencia/carta-servicos/avaliar")
  previsaoEspera String?
  prioridades    String?
  requisitos     String?
  statusServico  String?
  linkAcesso     String?
  avaliacoes     AvaliacaoServico[]
}

model AvaliacaoServico {
  id           String       @id @default(cuid())
  servicoId    String
  nota         Int
  comentario   String?
  respondidoEm DateTime     @default(now())
  servico      ServicoCarta @relation(fields: [servicoId], references: [id], onDelete: Cascade)
}

model RelatorioFiscal {
  id             String   @id @default(cuid())
  titulo         String
  tipo           String
  periodo        String
  ano            Int
  arquivo        String
  dataPublicacao DateTime @default(now())
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
}

model Pagamento {
  id             String    @id @default(cuid())
  ordem          Int
  fornecedor     String
  cnpj           String
  descricao      String
  valor          Float
  dataEmpenho    DateTime
  dataLiquidacao DateTime
  dataPagamento  DateTime?
  secretaria     String
  status         String    @default("pendente")
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt
}

model RenunciaFiscal {
  id            String   @id @default(cuid())
  descricao     String
  categoria     String
  baseLegal     String
  valorEstimado Float
  beneficiarios String?
  vigencia      String?
  ano           Int
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt
}

model QuadroServidor {
  id            String   @id @default(cuid())
  cargo         String
  vinculo       String   @default("efetivo")
  leiCriacao    String?
  vagasLei      Int
  vagasOcupadas Int
  vagasLivres   Int      @default(0)
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @default(now()) @updatedAt
}

model EmendaPix {
  id                    String    @id @default(cuid())
  ano                   Int
  origem                String // Federal ou Estadual
  tipoEmenda            String? // Individual, Bancada, etc
  formaRepasse          String?   @default("Transferência Especial - PIX")
  numeroEmenda          String?
  autor                 String
  beneficiario          String
  cnpjBeneficiario      String?
  valorPrevisto         Float     @default(0)
  valorRecebido         Float     @default(0)
  valorExecutado        Float     @default(0)
  objeto                String?
  funcaoGoverno         String?
  secretariaResponsavel String?
  situacao              String    @default("Recebido")
  dataRecebimento       DateTime?
  prazoExecucao         DateTime?
  contaBancaria         String?
  naturezaDespesa       String?
  arquivo               String?
  documentUrl           String?
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @default(now()) @updatedAt
}

model PesquisaSatisfacao {
  id                         String   @id @default(cuid())
  cpf                        String
  avaliacaoGestao            Int
  avaliacaoOuvidoria         Int
  satisfacaoTransparencia    Int
  avaliacaoLixo              Int
  avaliacaoLimpezaRuas       Int
  avaliacaoPatrimonio        Int
  avaliacaoPracas            Int
  avaliacaoCultura           Int
  avaliacaoIluminacao        Int
  avaliacaoSeguranca         Int
  avaliacaoEsporte           Int
  avaliacaoSaude             Int
  avaliacaoEducacao          Int
  avaliacaoAssistenciaSocial Int
  mes                        Int
  ano                        Int
  criadoEm                   DateTime @default(now())

  @@unique([cpf, mes, ano])
}
